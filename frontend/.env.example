# Public API (client-side). All VITE_* vars are inlined by Vite at build time.

# Base URL prefix for all backend requests. Default: /api/v1 (same-origin via nginx/proxy).
VITE_API_BASE_URL=/api/v1

# Request timeout in milliseconds, applied to every fetch via ky.timeout. Default: 10000.
VITE_DEFAULT_API_TIMEOUT_MS=10000

# In-memory cache TTL for the stations list (ms). Default: 300000 (5 minutes).
VITE_STATIONS_CACHE_MS=300000

# Fallback UI language when the browser language is not supported. Default: en. Supported: en, ru.
VITE_DEFAULT_LOCALE=en

# Sentry DSN. Empty/unset disables Sentry entirely.
VITE_SENTRY_DSN=

# Sentry environment tag. Defaults to the Vite MODE (development/production) if unset.
VITE_SENTRY_ENVIRONMENT=development

# Sentry performance sample rate (0.0–1.0). Default: 0.1.
VITE_SENTRY_SAMPLE_TRACE=0.1
