# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_DB=railway
POSTGRES_USER=railway
POSTGRES_PASSWORD=railway

# =============================================================================
# Django
# =============================================================================
DJANGO_SECRET_KEY=dev-insecure-secret-key-change-me
DJANGO_ALLOWED_HOSTS=localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost
# DJANGO_DEBUG=0                # 1 to enable debug mode + debug toolbar

# =============================================================================
# Redis
# =============================================================================
# REDIS_TIMEOUT=60              # default socket/op timeout (seconds)

# =============================================================================
# Cache TTLs (seconds, 0 = use built-in default)
# =============================================================================
# CACHE_TTL_STATIONS=0          # default: 86400 (1 day), signal-invalidated
# CACHE_TTL_SEARCH=0            # default: 30
# CACHE_TTL_SEATS=0             # default: 30, generation-keyed
# CACHE_TTL_STATION_ORDER_MAPS=0 # default: 60, signal-invalidated
# GENERATION_CACHE_TTL=0        # default: 604800 (7 days)

# =============================================================================
# Gunicorn (used in Dockerfile CMD)
# =============================================================================
# GUNICORN_WORKERS=             # default: (nproc * 2 + 1)
# GUNICORN_TIMEOUT=30
# GUNICORN_GRACEFUL_TIMEOUT=30
# GUNICORN_MAX_REQUESTS=1000
# GUNICORN_MAX_REQUESTS_JITTER=100

# =============================================================================
# DB connection pool (psycopg 3)
# =============================================================================
# DB_POOL_MIN_SIZE=2
# DB_POOL_MAX_SIZE=10
# DB_POOL_MAX_LIFETIME=600

# =============================================================================
# API / DRF
# =============================================================================
# THROTTLE_RATE_RPS=10
# BOOKING_THROTTLE_RATE_RPS=1

# =============================================================================
# Business defaults
# =============================================================================
# DEFAULT_BASE_PRICE=0          # constance BASE_PRICE initial value

# =============================================================================
# Logging
# =============================================================================
# LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# =============================================================================
# Sentry (error monitoring & performance tracing)
# =============================================================================
# SENTRY_DSN=                   # leave empty to disable Sentry
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# =============================================================================
# Frontend
# =============================================================================
VITE_API_BASE_URL=/api/v1  # Base URL prefix for all backend requests
VITE_DEFAULT_API_TIMEOUT_MS=10000  # Request timeout in milliseconds, applied to every fetch via ky.timeout
VITE_STATIONS_CACHE_MS=300000  # In-memory cache TTL for the stations list (ms)
VITE_DEFAULT_LOCALE=en  # Fallback UI language when the browser language is not supported (en/ru)
VITE_SENTRY_DSN=  # Sentry DSN. Empty/unset disables Sentry entirely.
VITE_SENTRY_ENVIRONMENT=development  # Sentry environment tag. Defaults to the Vite MODE (development/production)
VITE_SENTRY_SAMPLE_TRACE=0.1  # Sentry performance sample rate (0.0–1.0)
